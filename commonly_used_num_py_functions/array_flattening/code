import numpy as np

# Example exam scores (you can replace with the given one)
exam_scores = np.array([[75, 82, 90],
                        [92, 88, 78],
                        [60, 70, 85]])

# Flatten using different methods
exam_scores_flattened = exam_scores.flatten()
exam_scores_reshaped = exam_scores.reshape(-1)
exam_scores_raveled = exam_scores.ravel()

# Only flatten() is a COPY, so we modify this one
exam_scores_flattened[0] = 100

print("Flattened (copy):", exam_scores_flattened)
print("Reshaped (view):", exam_scores_reshaped)
print("Raveled (view):", exam_scores_raveled)
print("Original:", exam_scores)